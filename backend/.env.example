# App
APP_NAME=publisher
APP_VERSION=0.1.0
ENVIRONMENT=development
LOG_LEVEL=info
PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://publisher:publisher@db:5432/publisher

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET=change-me-in-production-use-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# Cookie encryption — must be exactly 32 bytes (base64-encoded)
# Generate: python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
COOKIE_ENCRYPTION_KEY=CHANGE_ME_32_BYTE_BASE64_ENCODED_KEY=

# CORS
ALLOWED_ORIGINS=http://localhost:5173

# Admin seed (for first-run)
SEED_ADMIN_EMAIL=admin@publisher.local
SEED_ADMIN_PASSWORD=change-me-on-first-login

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Browser Farm
BROWSER_MAX_SESSIONS=100
BROWSER_HEADLESS=true
BROWSER_TIMEOUT_MS=60000
