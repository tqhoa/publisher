{
  "title": "Publisher — Browser Farm",
  "uid": "browser-farm",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Active Sessions",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "browser_sessions_active",
          "legendFormat": "Active"
        }
      ]
    },
    {
      "id": 2,
      "title": "Session Status",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 0, "w": 18, "h": 8 },
      "targets": [
        {
          "expr": "browser_sessions_idle",
          "legendFormat": "Idle"
        },
        {
          "expr": "browser_sessions_busy",
          "legendFormat": "Busy"
        },
        {
          "expr": "browser_sessions_crashed",
          "legendFormat": "Crashed"
        }
      ]
    }
  ]
}
